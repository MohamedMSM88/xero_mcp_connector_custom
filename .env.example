# Copy to .env for LOCAL testing only. Never commit the real .env.
# Optional: if omitted, tokens are stored in a local JSON file (lost on restarts
# on most PaaS unless you attach persistent disk).
DATABASE_URL=postgresql://user:pass@host/dbname
TOKEN_STORE_PATH=xero_tokens.json
XERO_CLIENT_ID=your-client-id
XERO_CLIENT_SECRET=your-client-secret
XERO_REDIRECT_URI=https://xero-mcp-connector.onrender.com/callback
